# Copy to terraform.tfvars — never commit that file (contains secrets)

aws_region    = "us-east-1"
instance_type = "t3.medium"

# GitHub repository the runner will register against
github_repo = "nehaeglund/claude-github-demo"

# GitHub PAT with repo scope
# Create at: https://github.com/settings/tokens → Fine-grained → Administration: write
github_pat = "github_pat_..."

runner_name    = "nightlyjobs-runner"
runner_labels  = "nightlyjobs,self-hosted,linux,x64"
runner_version = "2.317.0"